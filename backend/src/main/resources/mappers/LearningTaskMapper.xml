<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.learning.infrastructure.persistence.LearningTaskMapper">

    <resultMap id="LearningTaskMap" type="com.example.learning.infrastructure.persistence.MyBatisLearningTaskRecord">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="dueDate" column="due_date"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumns">
        id, title, description, status, due_date, created_at, updated_at
    </sql>

    <insert id="insert" parameterType="com.example.learning.infrastructure.persistence.MyBatisLearningTaskRecord"
            useGeneratedKeys="true" keyProperty="id">
        insert into learning_task (title, description, status, due_date, created_at, updated_at)
        values (#{title}, #{description}, #{status}, #{dueDate}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update" parameterType="com.example.learning.infrastructure.persistence.MyBatisLearningTaskRecord">
        update learning_task
        set title = #{title},
            description = #{description},
            status = #{status},
            due_date = #{dueDate},
            updated_at = #{updatedAt}
        where id = #{id}
    </update>

    <select id="findById" resultMap="LearningTaskMap">
        select <include refid="BaseColumns"/>
        from learning_task
        where id = #{id}
    </select>

    <select id="findAll" resultMap="LearningTaskMap">
        select <include refid="BaseColumns"/>
        from learning_task
        <where>
            <if test="status != null">
                and status = #{status}
            </if>
            <if test="keyword != null">
                and (title like concat('%', #{keyword}, '%')
                    or description like concat('%', #{keyword}, '%'))
            </if>
            <if test="overdueOnly">
                and status != 'DONE'
                and due_date is not null
                and due_date &lt; current_date
            </if>
        </where>
        order by created_at desc
    </select>

    <delete id="deleteById">
        delete from learning_task
        where id = #{id}
    </delete>
</mapper>
