{
  "name": "learn-java-mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:h5": "unh dev",
    "dev:h5:mock": "VITE_USE_MOCK=true unh dev",
    "dev:h5:mock:empty": "VITE_USE_MOCK=true VITE_MOCK_SCENARIO=empty unh dev",
    "dev:h5:mock:many": "VITE_USE_MOCK=true VITE_MOCK_SCENARIO=many unh dev",
    "dev:h5:mock:error": "VITE_USE_MOCK=true VITE_MOCK_SCENARIO=serverError unh dev",
    "build:h5": "unh build --platform h5",
    "build:h5:mock": "VITE_USE_MOCK=true unh build --platform h5",
    "typecheck": "vue-tsc --noEmit",
    "test:unit": "vitest run -c vitest.config.ts",
    "test:coverage": "vitest run -c vitest.config.ts --coverage",
    "test:e2e:h5": "playwright test -c playwright.h5.config.ts",
    "test:e2e:h5:ui": "playwright test -c playwright.h5.config.ts --ui",
    "check": "npm-run-all typecheck test:unit build:h5 build:h5:mock"
  },
