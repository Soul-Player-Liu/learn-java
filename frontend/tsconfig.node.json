{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "types": ["node", "vite/client"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@learn-java/task-api": ["../packages/task-api/src/index.ts"],
      "@learn-java/task-domain": ["../packages/task-domain/src/index.ts"],
      "@learn-java/mock-data": ["../packages/mock-data/src/index.ts"]
    },
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true
  },
  "include": ["env.d.ts", "vite.config.ts", "playwright.config.ts", "eslint.config.js", ".storybook/**/*.ts"]
}
